<?xml version="1.0" encoding="utf-8"?>
<Configuration>
	<Feature Name="Toast" Enabled="True" /> <!-- Enables or disables the entire toast notification -->
	<Feature Name="PendingRebootUptime" Enabled="False" />	<!-- Enables the toast for reminding users of restarting their device if it exceeds the uptime defined in MaxUptimeDays -->
	<Feature Name="WeeklyMessage" Enabled="False" /> <!-- Enables weekly reminder messages on specified day and hour -->
	<Option Name="MaxUptimeDays" Value="-6" />	<!-- When using the toast for checking for pending reboots. A reboot is considered pending if computer uptime exceeds the value set here -->
	<Option Name="WeeklyMessageDay" Value="4" /> <!-- Numeric day(s) when WeeklyMessage should trigger (1=Monday, 2=Tuesday, 3=Wednesday, 4=Thursday, 5=Friday, 6=Saturday, 7=Sunday). Single day: 3 | Multiple days: 1,3,5 | All weekdays: 1,2,3,4,5 -->
	<Option Name="WeeklyMessageHour" Value="-1" /> <!-- Hour when WeeklyMessage should trigger (-1=any hour during target day, 0-23=specific hour in 24-hour format) -->
	<Option Name="PendingRebootUptimeText" Enabled="False" />	<!-- Adds an additional group to the toast with text about the uptime of the computer -->
	<Option Name="CustomNotificationApp" Enabled="True" Value="IT NOTIFICATIONS"/>	<!-- The app in Windows doing the actual notification. When enabled, uses custom app. When disabled, automatically defaults to PowerShell app for reliable notification delivery -->
	<Option Name="LogoImageName" Value="C:\ProgramData\ToastNotification\Images\logo-info.png" />  <!-- File name of the image shown as logo in the toast notoification  -->
	<Option Name="HeroImageName" Value="C:\ProgramData\ToastNotification\Images\hero-info.png" /> <!-- File name of the image shown in the top of the toast notification -->	
	<Option Name="ActionButton1" Enabled="True" />	<!-- Enables or disables the action button. -->
	<Option Name="ActionButton2" Enabled="False" />	<!-- Enables or disables the action button. -->
	<Option Name="DismissButton" Enabled="True" />	<!-- Enables or disables the dismiss button. -->
	<Option Name="SnoozeButton" Enabled="False" /> <!-- Enabling this option will always enable action button and dismiss button -->
	<Option Name="Scenario" Type="short" />	<!-- Possible values are: reminder | short | long | alarm -->
	<Option Name="Action1" Value="softwarecenter:Page=Applications" />	<!-- Action taken when using the Action button. Can be any protocol in Windows -->
	<Option Name="Action2" Value="" />	<!-- Action taken when using the Action button. Can be any protocol in Windows -->
	<Text Option="MultiLanguageSupport" Enabled="False" /> <!-- Enable support for multiple languages. If set to True, the toast notification will look for the users language culture within the config file -->
	<en-US> <!-- Default fallback language. German (de-DE) text is used here intentionally because MultiLanguageSupport is set to False, so the script always reads from the en-US block -->
        <Text Name="PendingRebootUptimeText"></Text> <!-- Text used if the PendingRebootUptimeText Option is enabled -->
        <Text Name="WeeklyMessageTitle"></Text> <!-- Title text for weekly message notifications -->
        <Text Name="WeeklyMessageBody"></Text> <!-- Body text for weekly message notifications -->
        <Text Name="ActionButton1">Software Center öffnen</Text>  <!-- Text on the ActionButton if enabled -->
		<Text Name="ActionButton2"></Text>  <!-- Text on the ActionButton if enabled -->
        <Text Name="DismissButton">Schließen</Text> <!-- Text on the DismissButton if enabled -->
        <Text Name="SnoozeButton">Später erinnern</Text> <!-- Text on the SnoozeButton if enabled -->
        <Text Name="AttributionText"></Text>
        <Text Name="HeaderText"></Text>
        <Text Name="TitleText"></Text>
        <Text Name="BodyText1"></Text>
        <Text Name="BodyText2"></Text>
        <Text Name="SnoozeText">Klicken Sie auf Erinnern, um erneut erinnert zu werden:</Text>
        <Text Name="GreetMorningText">Guten Morgen</Text>
        <Text Name="GreetAfternoonText">Guten Tag</Text>
        <Text Name="GreetEveningText">Guten Abend</Text>
        <Text Name="MinutesText">Minuten</Text>
        <Text Name="HourText">Stunde</Text>
        <Text Name="HoursText">Stunden</Text>
        <Text Name="ComputerUptimeText">Computer-Laufzeit:</Text>
        <Text Name="ComputerUptimeDaysText">Tage</Text>
    </en-US>
</Configuration>
